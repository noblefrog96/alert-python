[phases.setup]
nixPkgs = [
  "python311",
  "gcc",
  "glib",
  "nss",
  "nspr",
  "atk",
  "at-spi2-atk",
  "cups",
  "drm",
  "dbus",
  "expat",
  "xcb-util-cursor",
  "libxkbcommon",
  "pango",
  "cairo",
  "alsa-lib",
  "libxcomposite",
  "libxdamage",
  "libxfixes",
  "libxrandr",
  "mesa",
  "gbm",
  "gtk3"
]

[phases.install]
cmds = [
  "pip install -r requirements.txt",
  "playwright install chromium"
]

[start]
cmd = "python alert.py"